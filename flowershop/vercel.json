{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "python manage.py migrate && python manage.py init_data && python manage.py collectstatic --noinput",
  "functions": {
    "api/index.py": {
      "excludeFiles": "{.env,.history/**,media/**,__pycache__/**,**/__pycache__/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
