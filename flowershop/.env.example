# Example production environment variables
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com
ADMIN_URL=secure-admin/
ADMIN_USERNAME=admin
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Database
DATABASE_URL=
DB_ENGINE=django.db.backends.postgresql
DB_NAME=flowershop
DB_USER=flowershop_user
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=replace-with-email-app-password
DEFAULT_FROM_EMAIL=no-reply@your-domain.com

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000,https://your-domain.com,https://www.your-domain.com

# Payments
STRIPE_PUBLIC_KEY=pk_live_replace_me
STRIPE_SECRET_KEY=sk_live_replace_me
